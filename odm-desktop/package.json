{
  "name": "odm-desktop",
  "version": "1.0.5",
  "description": "ODM — Open Downloader Manager desktop shell",
  "main": "src/main.cjs",
  "private": true,
  "scripts": {
    "dev": "cross-env ODM_DEV=1 electron .",
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "cross-env": "^7.0.3",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.opendownloader.odm",
    "productName": "ODM",
    "artifactName": "ODM-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "scripts/after-pack.cjs",
    "afterSign": "scripts/notarize.cjs",
    "files": [
      "src/**/*",
      "scripts/**/*",
      "app/**/*"
    ],
    "extraResources": [
      {
        "from": "../resources/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../resources/jdk",
        "to": "jdk",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "ODM",
            "CFBundleURLSchemes": [
              "odm",
              "magnet"
            ]
          }
        ]
      }
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network"
    }
  }
}
