{
  "manifest_version": 3,
  "name": "ODM Integration",
  "short_name": "ODM",
  "version": "1.0.5",
  "description": "Captures downloads from Chrome and routes them to the ODM desktop app, IDM-style.",
  "minimum_chrome_version": "108",
  "key": "",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "ODM Integration",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "options.html",
  "permissions": [
    "downloads",
    "webRequest",
    "storage",
    "contextMenus",
    "cookies",
    "notifications",
    "nativeMessaging",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
