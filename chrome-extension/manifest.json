{
  "manifest_version": 3,
  "name": "ODM Integration",
  "short_name": "ODM",
  "version": "1.0.0",
  "description": "Captures downloads from Chrome and routes them to the ODM desktop app, IDM-style.",
  "minimum_chrome_version": "108",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_title": "ODM Integration",
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "options_page": "options.html",
  "permissions": [
    "downloads",
    "nativeMessaging",
    "storage",
    "contextMenus",
    "cookies",
    "notifications",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
